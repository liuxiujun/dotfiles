# basic settings
set clipboard=unnamed
set hlsearch
set incsearch
set ignorecase
set smartcase
set contentassistmode

set number
# key mappings 
let mapleader = ","

" save 
nnoremap <leader>s :w<CR>

" close 
nnoremap <leader>x :q<CR>
nnoremap <leader>X :qa<CR>

" source vimrc
nnoremap <leader>. :e C:/Users/liuxi/.vrapperrc<CR>
# nnoremap <leader>0 :so C:/Users/liuxi/.vrapperrc<CR>

" switch between tabs
nnoremap <Tab> :tabn<CR>
nnoremap <S-Tab> :tabp<CR>
